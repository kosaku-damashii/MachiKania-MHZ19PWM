REM MHZ19PWM.BAS

USEVAR GP,MDR,NP,OP,HT,LT

REM Digital I/O port
GP=0
REM GP=1


REM Max Detection Range
REM MDR=2000
MDR=5000

REM 1ms
USETIMER 1000

CLS
NP=IN(GP)
HT=0:LT=0
WHILE 1
 I=0
 DO
  WHILE TIMER()==0
   IDLE
  WEND
  NP=IN(GP)
  I=I+1
 LOOP WHILE NP==OP
 OP=NP
 IF NP==1 THEN  
  LT=I
  IF HT!=0 THEN
   PRINT MDR*(HT-2)/(HT+LT-4)
  ENDIF
 ELSE
  HT=I
 ENDIF
 I=0
WEND
END
